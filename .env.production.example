# Krovara prod env. Copy to `.env` next to docker-compose.yml and edit.
# Required values are marked REQUIRED — compose will refuse to start without them.

# --- Domain & TLS ---------------------------------------------------------
KROVARA_DOMAIN=krovara.example.com          # REQUIRED — points your DNS A record here
KROVARA_TLS_EMAIL=ops@example.com           # REQUIRED — Let's Encrypt account email

# --- Postgres -------------------------------------------------------------
POSTGRES_USER=krovara
POSTGRES_DB=krovara
POSTGRES_PASSWORD=                          # REQUIRED — strong random

# --- API ------------------------------------------------------------------
KROVARA_JWT_SECRET=                         # REQUIRED — 32+ random bytes, base64 or hex

# --- OAuth (optional, leave blank to disable a provider) -----------------
# Register the redirect URI with each provider as the BACKEND callback on your
# domain: https://<KROVARA_DOMAIN>/api/auth/google/callback (and .../github/...).
KROVARA_OAUTH_GOOGLE_CLIENT_ID=
KROVARA_OAUTH_GOOGLE_CLIENT_SECRET=
KROVARA_OAUTH_GOOGLE_REDIRECT_URL=        # https://<domain>/api/auth/google/callback
KROVARA_OAUTH_GITHUB_CLIENT_ID=
KROVARA_OAUTH_GITHUB_CLIENT_SECRET=
KROVARA_OAUTH_GITHUB_REDIRECT_URL=        # https://<domain>/api/auth/github/callback

# --- Captcha — Cloudflare Turnstile (ADR-030, optional) ------------------
KROVARA_TURNSTILE_SECRET=                    # backend siteverify secret; blank → captcha disabled
PUBLIC_TURNSTILE_SITEKEY=                    # front widget site key (web/ build-time)

# --- Anti-double-compte — signal IP haché (ADR-031, optional) ------------
KROVARA_SIGNUP_IP_KEY=                       # HMAC key; blank → no signup-IP fingerprint; 32+ random bytes
KROVARA_TRUST_PROXY=true                      # REQUIRED behind Caddy/Cloudflare: read real client IP.
                                              # Caddy forwards X-Real-IP from Cloudflare's CF-Connecting-IP
                                              # (see caddy/Caddyfile + docs/DEPLOYMENT.md); else everyone
                                              # shares the proxy IP for rate-limit + signup fingerprint.

# --- Krovara+ billing — Stripe (ADR-037, optional; blank → billing disabled) ---
# Create a recurring Price in Stripe; add a webhook → https://<DOMAIN>/api/billing/webhook
# (events: checkout.session.completed, customer.subscription.*); paste its signing
# secret below. Step-by-step in docs/DEPLOYMENT.md.
KROVARA_STRIPE_SECRET_KEY=                   # sk_live_… (sk_test_… in test mode)
KROVARA_STRIPE_WEBHOOK_SECRET=               # whsec_… from the webhook endpoint
KROVARA_STRIPE_PRICE_ID=                     # price_… of the Krovara+ recurring price

# --- Email — Resend (ADR-038, optional; blank → confirmation links are logged) ---
KROVARA_RESEND_API_KEY=                      # re_… ; verify your sending domain in Resend first
KROVARA_EMAIL_FROM=Krovara <no-reply@krovara.example.com>   # must be a verified sender identity

# --- Search — Meilisearch (optional) -------------------------------------
MEILI_MASTER_KEY=                           # REQUIRED if meilisearch service is up; random 32+ bytes
KROVARA_MEILI_HOST=http://meilisearch:7700  # API → Meili URL; blank disables search

# --- GIF — KLIPY (ADR-021, optional; blank → GIF picker disabled) ---------
KROVARA_KLIPY_API_KEY=

# --- CORS for packaged apps — Tauri desktop/Android (optional) ------------
# Blank → no-op (the same-origin web app needs no CORS). Set to the bundled
# clients' webview origins so their cross-origin API calls are allowed.
# Windows WebView2 = http://tauri.localhost · Linux/macOS = tauri://localhost
# · Android = http://tauri.localhost. See docs/DESKTOP-MOBILE.md.
KROVARA_CORS_ORIGINS=

# --- Antivirus — ClamAV (ADR-022, optional; blank → uploads marked clean) --
KROVARA_CLAMAV_ADDR=                         # host:port of clamd (e.g. clamav:3310)

# --- VoIP (optional, sessions 17 + 23b) ----------------------------------
COTURN_AUTH_SECRET=                         # REQUIRED if coturn service is up; random 32+ bytes
KROVARA_TURN_URIS=                          # CSV: turn:turn.example.com:3478?transport=udp,turn:...
# The voip (SFU) service reuses KROVARA_JWT_SECRET above and derives its
# allowed WebSocket origin from KROVARA_DOMAIN — no extra vars needed.
# KROVARA_APP_URL is derived in compose from KROVARA_DOMAIN (https://<domain>).

# --- Monitoring overlay (optional, monitoring/docker-compose.monitoring.yml) ---
GRAFANA_ADMIN_PASSWORD=                      # REQUIRED if the monitoring overlay is up
KROVARA_STATUS_DOMAIN=status.krovara.com     # Caddy vhost for the Uptime Kuma status page (needs its own DNS A record)

# --- Versioning -----------------------------------------------------------
KROVARA_VERSION=latest
