-- Bot components for Krovara (XEP-0114). Generated by hand from
-- `POST /api/spaces/:id/bots` responses. Copy this file to
-- /etc/prosody/components.cfg.lua and reload:
--
--     docker compose exec prosody prosodyctl reload
--
-- One Component entry per bot. The JID must match the one returned by
-- the API; the secret is the `secret` field (shown only once on create).

-- Component "bot-abc123de.krovara.local"
--     component_secret = "REPLACE_ME"

-- Component "bot-def456ab.krovara.local"
--     component_secret = "REPLACE_ME"
