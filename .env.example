# Database
PG_DSN=postgres://krovara:krovara@localhost:5432/krovara?sslmode=disable

# Auth
JWT_SECRET=change-me-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Server
HTTP_ADDR=:8080
LOG_LEVEL=debug
LOG_FORMAT=text

# OAuth2 (session 03)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Captcha — Cloudflare Turnstile (ADR-030). Both blank → captcha disabled.
KROVARA_TURNSTILE_SECRET=                    # backend siteverify secret
PUBLIC_TURNSTILE_SITEKEY=                    # front widget site key (web/ build-time)

# Anti-double-compte (ADR-031). Blank → no signup-IP fingerprint captured.
KROVARA_SIGNUP_IP_KEY=                       # HMAC key; rotating it drops historical correlation

# XMPP / Prosody (session 08)
XMPP_DOMAIN=krovara.local
XMPP_ADMIN_SECRET=

# Storage
DATA_DIR=./data
