// Krovara — schéma de la base (PostgreSQL 16)
// Généré depuis migrations/. Colle dans https://dbdiagram.io pour le rendu.

Table users {
  id uuid [pk]
  username text [unique, not null]
  email text [unique, not null]
  password_hash text
  avatar_key text
  created_at timestamptz
}

Table oauth_accounts {
  id uuid [pk]
  user_id uuid
  provider text [not null]
  provider_id text [not null]
}

Table sessions {
  id uuid [pk]
  user_id uuid
  refresh_token text [unique, not null]
  expires_at timestamptz [not null]
  created_at timestamptz
}

Table spaces {
  id uuid [pk]
  owner_id uuid
  name text [not null]
  icon_key text
  created_at timestamptz
}

Table channels {
  id uuid [pk]
  space_id uuid
  name text [not null]
  topic text
  type text
  position int
  is_private boolean
  created_at timestamptz
}

Table members {
  id uuid [pk]
  space_id uuid
  user_id uuid
  nickname text
  joined_at timestamptz
}

Table roles {
  id uuid [pk]
  space_id uuid
  name text [not null]
  permissions bigint
  color text
  position int
  is_everyone boolean
}

Table member_roles {
  member_id uuid
  role_id uuid
}

Table channel_overwrites {
  channel_id uuid
  role_id uuid
  allow bigint
  deny bigint
}

Table files {
  id uuid [pk]
  owner_id uuid
  filename text [not null]
  size bigint [not null]
  mimetype text [not null]
  path text [not null]
  created_at timestamptz
}

Table invites {
  id uuid [pk]
  space_id uuid
  creator_id uuid
  code text [unique, not null]
  max_uses int
  uses int
  expires_at timestamptz
  created_at timestamptz
}

Table bans {
  id uuid [pk]
  space_id uuid
  user_id uuid
  moderator_id uuid
  reason text
  created_at timestamptz
}

Table audit_logs {
  id uuid [pk]
  space_id uuid
  actor_id uuid
  action text [not null]
  target_id uuid
  metadata jsonb
  created_at timestamptz
}

Table webhooks {
  id uuid [pk]
  space_id uuid
  channel_id uuid
  name text [not null]
  url text [not null]
  secret text
  events text[] [not null]
  created_at timestamptz
}

Table reports {
  id uuid [pk]
  reporter_id uuid
  target_type text [not null]
  target_id uuid [not null]
  reason text [not null]
  status text
  created_at timestamptz
}

Table xmpp_tokens {
  token text [pk]
  user_id uuid [not null]
  expires_at timestamptz [not null]
  created_at timestamptz [not null]
}

Table bots {
  id uuid [pk]
  space_id uuid [not null]
  name text [not null]
  component_jid text [unique, not null]
  secret_hash text [not null]
  created_at timestamptz [not null]
}

Table devices {
  id uuid [pk]
  user_id uuid [not null]
  name text [not null]
  ntfy_topic text [not null]
  created_at timestamptz [not null]
}

Table push_prefs {
  user_id uuid [not null]
  space_id uuid [not null]
  scope text [not null]
}

Table message_pins {
  id uuid [pk]
  channel_id uuid [not null]
  archive_id text [not null]
  pinned_by uuid [not null]
  note text [not null]
  created_at timestamptz [not null]
}

Table saved_messages {
  id uuid [pk]
  user_id uuid [not null]
  channel_id uuid [not null]
  archive_id text [not null]
  folder text [not null]
  created_at timestamptz [not null]
}

Table channel_read_state {
  user_id uuid [not null]
  channel_id uuid [not null]
  last_read_sort_id bigint [not null]
  last_read_archive_id text [not null]
  updated_at timestamptz [not null]
}

Table malicious_urls {
  url_hash text [pk]
  threat text
  added_at timestamptz [not null]
}

Table threads {
  id uuid [pk]
  channel_id uuid [not null]
  root_archive_id text [not null]
  title text [not null]
  created_by uuid [not null]
  created_at timestamptz [not null]
  last_activity_at timestamptz [not null]
}

Table thread_subscriptions {
  user_id uuid [not null]
  thread_id uuid [not null]
  created_at timestamptz [not null]
}

Table categories {
  id uuid [pk]
  space_id uuid [not null]
  name text [not null]
  position int [not null]
  created_at timestamptz [not null]
}

Table mod_actions {
  id uuid [pk]
  space_id uuid [not null]
  target_user uuid [not null]
  moderator_id uuid
  action text [not null]
  reason text
  expires_at timestamptz
  active boolean [not null]
  created_at timestamptz [not null]
}

Table friendships {
  id uuid [pk]
  requester_id uuid [not null]
  addressee_id uuid [not null]
  status text [not null]
  created_at timestamptz [not null]
}

Table blocks {
  blocker_id uuid [not null]
  blocked_id uuid [not null]
  created_at timestamptz [not null]
}

Table notif_settings {
  user_id uuid [not null]
  scope_type text [not null]
  scope_id uuid [not null]
  level text [not null]
  muted_until timestamptz
  suppress_everyone boolean [not null]
}

Table inbox_items {
  id uuid [pk]
  user_id uuid [not null]
  kind text [not null]
  space_id uuid
  channel_id uuid
  archive_id text [not null]
  author_id uuid
  preview text
  read boolean [not null]
  created_at timestamptz [not null]
}

Table games {
  id uuid [pk]
  name text [not null]
  cover_key text
  status text [not null]
  submitted_by uuid
  reviewed_by uuid
  reject_reason text
  aliases text[] [not null]
  created_at timestamptz [not null]
}

Table tasks {
  id uuid [pk]
  space_id uuid [not null]
  channel_id uuid
  source_archive_id text
  title text [not null]
  assignee_id uuid
  due_at timestamptz
  status text [not null]
  created_by uuid
  created_at timestamptz [not null]
}

Table api_tokens {
  id uuid [pk]
  user_id uuid [not null]
  name text [not null]
  token_hash text [unique, not null]
  prefix text [not null]
  scopes text[] [not null]
  last_used_at timestamptz
  created_at timestamptz [not null]
}

Table space_listings {
  space_id uuid [pk]
  category text [not null]
  member_count int [not null]
  listed_at timestamptz [not null]
  delisted_at timestamptz
}

Table message_follows {
  user_id uuid [not null]
  channel_id uuid [not null]
  archive_id text [not null]
  created_at timestamptz [not null]
}

Table karma {
  user_id uuid [not null]
  space_id uuid [not null]
  score integer [not null]
  updated_at timestamptz [not null]
}

Table karma_events {
  id uuid [pk]
  space_id uuid [not null]
  target_user uuid [not null]
  source_user uuid [not null]
  delta integer [not null]
  reason text [not null]
  created_at timestamptz [not null]
}

Table join_forms {
  space_id uuid [pk]
  enabled boolean [not null]
  questions jsonb [not null]
  auto_role_id uuid
  updated_at timestamptz [not null]
}

Table join_requests {
  id uuid [pk]
  space_id uuid [not null]
  user_id uuid [not null]
  answers jsonb [not null]
  status text [not null]
  reviewed_by uuid
  reviewed_at timestamptz
  created_at timestamptz [not null]
}

Table saved_searches {
  id uuid [pk]
  user_id uuid [not null]
  space_id uuid
  name text [not null]
  query text [not null]
  created_at timestamptz [not null]
}

Table polls {
  id uuid [pk]
  space_id uuid [not null]
  channel_id uuid [not null]
  question text [not null]
  created_by uuid [not null]
  closed boolean [not null]
  created_at timestamptz [not null]
}

Table poll_options {
  id uuid [pk]
  poll_id uuid [not null]
  label text [not null]
  position int [not null]
}

Table poll_votes {
  poll_id uuid [not null]
  option_id uuid [not null]
  user_id uuid [not null]
  voted_at timestamptz [not null]
}

Table events {
  id uuid [pk]
  space_id uuid [not null]
  title text [not null]
  description text
  location text
  starts_at timestamptz [not null]
  created_by uuid [not null]
  created_at timestamptz [not null]
}

Table event_rsvps {
  event_id uuid [not null]
  user_id uuid [not null]
  status text [not null]
  responded_at timestamptz [not null]
}

Table custom_emojis {
  id uuid [pk]
  space_id uuid [not null]
  name text [not null]
  file_key text [not null]
  animated boolean [not null]
  created_by uuid
  created_at timestamptz [not null]
}

Table report_comments {
  id uuid [pk]
  report_id uuid [not null]
  author_id uuid
  body text [not null]
  created_at timestamptz [not null]
}

Table email_change_tokens {
  id uuid [pk]
  user_id uuid [not null]
  new_email text [not null]
  token_hash text [unique, not null]
  expires_at timestamptz [not null]
  used_at timestamptz
  created_at timestamptz [not null]
}

Table banned_identifiers {
  id uuid [pk]
  kind text [not null]
  value text [not null]
  reason text
  banned_by uuid
  created_at timestamptz [not null]
}

Table email_verifications {
  user_id uuid [pk]
  code_hash text [not null]
  expires_at timestamptz [not null]
  created_at timestamptz [not null]
}

Table dm_groups {
  id uuid [pk]
  owner_id uuid [not null]
  name text
  icon_key text
  created_at timestamptz [not null]
}

Table dm_group_members {
  group_id uuid [not null]
  user_id uuid [not null]
  joined_at timestamptz [not null]
}

Table dm_group_messages {
  id uuid [pk]
  group_id uuid [not null]
  author_id uuid [not null]
  body text [not null]
  created_at timestamptz [not null]
}

Table dm_group_invites {
  code text [pk]
  group_id uuid [not null]
  created_by uuid [not null]
  created_at timestamptz [not null]
}

