# Krovara — Caddy reverse proxy (prod).
#
# Auto-TLS Let's Encrypt via the email in env. All HTTP traffic is HTTPS-
# redirected automatically by Caddy when a site address is a domain.
#
# Routing:
#   /api/*             → api:8080      (Go API)
#   /voip/ws           → voip:8083     (SFU signaling — WebSocket)
#   /xmpp-websocket    → prosody:5280  (WebSocket upgrade)
#   /upload/*          → prosody:5280  (XEP-0363 HTTP upload)
#   /                  → static SvelteKit bundle in /srv
#
# /internal/* is *not* exposed externally — the API only mounts it on a
# private listener (loopback) inside the api container.

{
    email {$KROVARA_TLS_EMAIL}
}

{$KROVARA_DOMAIN} {
    encode zstd gzip

    # Liveness probe → API. Public, cheap; target for deploy checks + Uptime Kuma.
    @health path /healthz
    handle @health {
        reverse_proxy api:8080
    }

    @api path /api/* /api
    handle @api {
        # Behind Cloudflare (the documented topology): the real visitor IP is in
        # CF-Connecting-IP. The API reads X-Real-IP for rate-limit + the signup-IP
        # anti-double-account signal, so forward it. If you run WITHOUT Cloudflare,
        # drop this line (else X-Real-IP would be empty). See docs/DEPLOYMENT.md.
        reverse_proxy api:8080 {
            header_up X-Real-IP {http.request.header.CF-Connecting-IP}
        }
    }

    @ws path /xmpp-websocket
    handle @ws {
        reverse_proxy prosody:5280
    }

    @voip path /voip/ws
    handle @voip {
        reverse_proxy voip:8083
    }

    @upload path /upload/* /upload
    handle @upload {
        reverse_proxy prosody:5280
    }

    @ntfy path /ntfy/*
    handle @ntfy {
        uri strip_prefix /ntfy
        reverse_proxy ntfy:80
    }

    # Static SvelteKit SPA — catch-all handler. This MUST be wrapped in its own
    # `handle {}`: `try_files` is a rewrite that, at the site level, runs before
    # the `handle @api`/`@ws` blocks and rewrites every path to /index.html, so
    # the API/WebSocket routes never match. Scoping it here fixes that.
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}

# --- Public status page (Uptime Kuma) ------------------------------------
# status.<domain> → uptime-kuma:3001, auto-TLS via the same ACME account.
# Requires: (1) a DNS A/AAAA record for this host → the server, and (2) the
# monitoring overlay running (monitoring/docker-compose.monitoring.yml), which
# provides the `uptime-kuma` upstream — otherwise this host returns 502.
# The page is public read-only; the admin dashboard sits behind the Uptime
# Kuma login. Caddy proxies the Socket.IO WebSocket transparently.
{$KROVARA_STATUS_DOMAIN:status.krovara.com} {
    encode zstd gzip
    reverse_proxy uptime-kuma:3001
}
